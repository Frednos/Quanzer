<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">


  <xacro:macro name="qube" params="prefix">
    <xacro:property name="stator_size" value="0.102"/>
    <xacro:property name="rotor_h"     value="0.01"/>
    <xacro:property name="rotor_r"     value="0.025"/>
    <xacro:property name="ind_l"       value="0.025"/>
    <xacro:property name="ind_w"       value="0.002"/>
    <xacro:property name="ind_h"       value="0.002"/>
    <xacro:property name="stator_half" value="${stator_size/2.0}"/>
    <xacro:property name="rotor_half"  value="${rotor_h/2.0}"/>
    <xacro:property name="rotor_z" value="${stator_half + rotor_half}"/>
    <xacro:property name="ind_x" value="${ind_l/2.0}"/>
    <xacro:property name="ind_z" value="${rotor_half + ind_h/2.0}"/>


    <link name="${prefix}stator_link">
      <visual>
        <geometry>
          <box size="${stator_size} ${stator_size} ${stator_size}"/>
        </geometry>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rotor_link">
      <visual>
        <geometry>
          <cylinder length="${rotor_h}" radius="${rotor_r}"/>
        </geometry>
        <material name="red">
          <color rgba="1 0 0 1"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}angle_link">
      <visual>
        <geometry>
          <box size="${ind_l} ${ind_w} ${ind_h}"/>
        </geometry>
        <material name="white">
          <color rgba="1 1 1 1"/>
        </material>
      </visual>
    </link>


    <joint name="${prefix}stator_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}stator_link"/>
      <origin xyz="0 0 ${stator_half}" rpy="0 0 0"/>
    </joint>


    <joint name="${prefix}motor_joint" type="revolute">
      <parent link="${prefix}stator_link"/>
      <child link="${prefix}rotor_link"/>
      <origin xyz="0 0 ${rotor_z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.14159" upper="3.14159" effort="1.0" velocity="2.0"/>
    </joint>


    <joint name="${prefix}indicator" type="fixed">
      <parent link="${prefix}rotor_link"/>
      <child link="${prefix}angle_link"/>
      <origin xyz="${ind_x} 0 ${ind_z}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>